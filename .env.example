# ── Required ──────────────────────────────────────────────────
SECRET_KEY=django-insecure-SCHIMBA-ASTA-IN-PRODUCTIE

# ── Debug ─────────────────────────────────────────────────────
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (SQLite implicit, PostgreSQL optional) ────────────
USE_POSTGRES=False

# PostgreSQL (doar daca USE_POSTGRES=True)
DB_NAME=iwb
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS (frontend URL) ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000
